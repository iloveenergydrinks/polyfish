{
  "name": "polyfish",
  "version": "0.1.0",
  "description": "PolyFish - Polymarket swarm prediction engine",
  "scripts": {
    "setup": "npm install && cd frontend && npm install",
    "setup:backend": "cd backend && uv sync",
    "setup:all": "npm run setup && npm run setup:backend",
    "dev": "concurrently --kill-others -n \"backend,frontend\" -c \"green,cyan\" \"npm run backend\" \"npm run frontend\"",
    "backend": "FLASK_DEBUG=true FLASK_PORT=5001 ./.venv/bin/python backend/run.py",
    "frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "stitch:landing": "node scripts/generate-stitch-landing.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "AGPL-3.0",
  "dependencies": {
    "@google/stitch-sdk": "^0.0.3"
  }
}
